# PostgreSQL Database Configuration
DATABASE_URL=postgresql://neondb_owner:your_password@your_host.neon.tech:5432/neondb?sslmode=require

# Data Input Path
# For local machine: /path/to/yellow_tripdata_2023-01.parquet
# For Kaggle: /kaggle/input/datasets/kurapatinikitha/nyc-taxi/yellow_tripdata_2023-01.parquet
PARQUET_PATH=/kaggle/input/datasets/kurapatinikitha/nyc-taxi/yellow_tripdata_2023-01.parquet

# Database Table Name
TABLE_NAME=yellow_taxi_2023

# Sample Size (rows to process)
# Full file: 2,850,000 rows
# Sample: 50,00,000 rows (recommended for free tier)
SAMPLE_SIZE=5000000

# Logging Level
LOG_LEVEL=INFO

# Optional: Data Output Directory
OUTPUT_DIR=./outputs
